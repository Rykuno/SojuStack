{
  "name": "api",
  "version": "0.0.1",
  "private": true,
  "description": "API for KimchiStack",
  "license": "UNLICENSED",
  "author": "Rykuno",
  "types": {
    "openapi": "./generated/openapi.d.ts"
  },
  "scripts": {
    "build": "nest build",
    "db:push": "drizzle-kit push",
    "db:pull": "drizzle-kit pull",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:reset": "drizzle-kit reset",
    "db:studio": "drizzle-kit studio",
    "dev": "vp run start:dev & vp run email:dev & vp run db:studio",
    "start:dev": "nest start --watch",
    "repl": "nest start --watch --entryFile repl",
    "email:dev": "email dev --dir ./src/mail/templates --port 3030",
    "nuke": "docker compose down -v --remove-orphans && docker compose up -d",
    "start": "nest start",
    "debug": "nest start --debug --watch",
    "start:prod": "node dist/main",
    "test:cov": "jest --coverage",
    "test:debug": "node --inspect-brk -r tsconfig-paths/register -r ts-node/register node_modules/.bin/jest --runInBand",
    "test:e2e": "jest --config ./test/jest-e2e.json",
    "test:watch": "jest --watch",
    "typecheck": "tsc --noEmit",
    "openapi:generate": "node -r tsconfig-paths/register -r ts-node/register src/common/utils/generate-openapi-types.ts",
    "depcheck": "depcheck"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "catalog:",
    "@keyv/redis": "catalog:",
    "@nest-lab/throttler-storage-redis": "catalog:",
    "@nestjs-cls/transactional": "catalog:",
    "@nestjs-cls/transactional-adapter-drizzle-orm": "catalog:",
    "@nestjs/axios": "catalog:",
    "@nestjs/bullmq": "catalog:",
    "@nestjs/cache-manager": "catalog:",
    "@nestjs/common": "^11.1.16",
    "@nestjs/config": "catalog:",
    "@nestjs/core": "^11.1.16",
    "@nestjs/platform-express": "^11.1.16",
    "@nestjs/swagger": "catalog:",
    "@nestjs/terminus": "catalog:",
    "@nestjs/throttler": "catalog:",
    "@paralleldrive/cuid2": "catalog:",
    "@react-email/components": "catalog:",
    "@react-email/render": "catalog:",
    "@redocly/openapi-core": "catalog:",
    "@scalar/nestjs-api-reference": "catalog:",
    "axios": "catalog:",
    "better-auth": "catalog:",
    "bullmq": "catalog:",
    "cacheable": "catalog:",
    "csrf-csrf": "catalog:",
    "date-fns": "catalog:",
    "dotenv": "catalog:",
    "drizzle-orm": "catalog:",
    "helmet": "catalog:",
    "keyv": "catalog:",
    "nestjs-cls": "catalog:",
    "nestjs-zod": "catalog:",
    "openapi-typescript": "catalog:",
    "pg": "catalog:",
    "react": "catalog:",
    "react-dom": "catalog:",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2",
    "sanitize-filename": "catalog:",
    "slugify": "catalog:",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.5",
    "@eslint/js": "^9.39.4",
    "@nestjs/cli": "^11.0.16",
    "@nestjs/schematics": "^11.0.9",
    "@nestjs/testing": "^11.1.16",
    "@react-email/preview-server": "catalog:",
    "@types/express": "^5.0.6",
    "@types/jest": "^30.0.0",
    "@types/multer": "catalog:",
    "@types/node": "^22.19.15",
    "@types/react": "catalog:",
    "@types/supertest": "^6.0.3",
    "drizzle-kit": "catalog:",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "globals": "^16.5.0",
    "jest": "^30.3.0",
    "prettier": "^3.8.1",
    "react-email": "catalog:",
    "source-map-support": "^0.5.21",
    "supertest": "^7.2.2",
    "ts-jest": "^29.4.6",
    "ts-loader": "^9.5.4",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.57.0"
  },
  "jest": {
    "collectCoverageFrom": [
      "**/*.(t|j)s"
    ],
    "coverageDirectory": "../coverage",
    "moduleFileExtensions": [
      "js",
      "json",
      "ts"
    ],
    "moduleNameMapper": {
      "^src/(.*)$": "<rootDir>/$1"
    },
    "rootDir": "src",
    "testEnvironment": "node",
    "testRegex": ".*\\.spec\\.ts$",
    "transform": {
      "^.+\\.(t|j)s$": "ts-jest"
    }
  }
}
